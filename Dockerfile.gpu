# VieNeu-TTS → OpenAI-compatible TTS shim — GPU build.
# Installs the PyTorch (CUDA 12.8) stack so the SDK runs on the GPU — matching the
# speed of the tts.starb.ca deployment. Run on an NVIDIA host with `--gpus all`
# (requires the NVIDIA driver + nvidia-container-toolkit).
#
# Choose the model with VIENEU_MODE (default v3turbo, GPU auto-detected):
#   v3turbo            v3 Turbo on GPU (PyTorch)         — what tts.starb.ca shows by default
#   fast | gpu         VieNeu-TTS-v2 (GPU, LMDeploy)
#   standard           VieNeu-TTS v1
#   remote             offload to a :23333 LMDeploy server (then this image is overkill — use the CPU one)
FROM nvidia/cuda:12.8.1-cudnn-runtime-ubuntu24.04

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/data/hf \
    VIENEU_MODE=v3turbo \
    VIENEU_EMOTION=natural

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       python3.12 python3-pip libsndfile1 ffmpeg curl \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3.12 /usr/local/bin/python

# Staged install (instead of vieneu[gpu]) so the image builds reliably:
#  1) PyTorch CUDA 12.8 wheels from the pytorch index.
#  2) Core shim + the deps v3 Turbo (GPU) actually needs: transformers/neucodec/librosa/triton.
#     This is enough for VIENEU_MODE=v3turbo (the tts.starb.ca default).
#  3) lmdeploy is best-effort — it enables VIENEU_MODE=fast (v2). If its wheel is
#     unavailable for this CUDA, the build still succeeds (v2 just won't be available).
# (llama-cpp-python / the v1 "standard" GGUF backend is intentionally omitted — it compiles
#  from source and isn't needed; add it yourself if you want VIENEU_MODE=standard.)
# Note: don't `pip install --upgrade pip` here — the apt-provided pip has no RECORD file
# and self-upgrade fails ("Cannot uninstall pip 24.0"). 24.0 installs the wheels fine.
ENV PIP_BREAK_SYSTEM_PACKAGES=1 PIP_ROOT_USER_ACTION=ignore
RUN python -m pip install --extra-index-url https://download.pytorch.org/whl/cu128 \
      torch==2.8.0 torchaudio==2.8.0
RUN python -m pip install \
      "vieneu==3.0.5" transformers "librosa>=0.11.0" "neucodec>=0.0.4" triton \
      "fastapi>=0.110" "uvicorn[standard]>=0.27" "soundfile>=0.12.1" numpy
RUN python -m pip install lmdeploy \
 || echo "WARNING: lmdeploy not installed — VIENEU_MODE=fast (v2) will be unavailable; v3turbo works."

COPY app.py .

RUN mkdir -p /data/hf
VOLUME ["/data/hf"]

EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=10s --start-period=240s --retries=5 \
    CMD curl -fsS http://localhost:8080/health || exit 1

CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "1"]
